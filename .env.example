# Banco de dados (compartilhado por agente, backend e frontend)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agente_financeiro

# OpenAI (usado pelo agente)
OPENAI_API_KEY=sk-...

# Evolution API (webhook do WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_INSTANCE=minha-instancia
EVOLUTION_API_KEY=sua-chave
WHATSAPP_ALLOWED_NUMBER=5511957818539

# Autenticação JWT (backend) — OBRIGATÓRIO
# Use um segredo forte e aleatório, >= 32 bytes. Ex.: python -c "import secrets; print(secrets.token_urlsafe(48))"
# O backend NÃO sobe se JWT_SECRET faltar.
JWT_SECRET=
JWT_ACCESS_EXPIRES_MIN=30
JWT_REFRESH_EXPIRES_DAYS=7
# Allowlist de admins (CSV de emails). Só emails aqui podem acessar /admin/*.
ADMIN_EMAILS=jhonatas2004@gmail.com

# Sessão do frontend Flask — OBRIGATÓRIO
# Segredo que assina o cookie de sessão. Use um valor forte e aleatório.
# O frontend NÃO sobe se SECRET_KEY faltar.
SECRET_KEY=

# Identidade do usuário dono das transações criadas pelo agente (WhatsApp)
AGENTE_USUARIO_EMAIL=jhonatas2004@gmail.com
